# ── Must-b Environment Configuration ────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Run `must-b onboard` for an interactive setup wizard.

# ── AI Provider ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4309
LOG_LEVEL=info

# ── Must-b Mode ──────────────────────────────────────────────────────────────
# local  — runs only on this machine, no external identity
# world  — cross-device mode, gets a unique MUSTB_UID
MUSTB_MODE=local

# ── World Identity (auto-generated by `must-b onboard` in world mode) ────────
MUSTB_UID=
