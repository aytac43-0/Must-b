{
  "name": "@must-b/must-b",
  "version": "1.2.3",
  "description": "Must-b v1.0 — Professional Autonomous AI Operating System by Auto Step",
  "files": [
    "dist/",
    "bin/",
    "install.sh",
    "install.ps1",
    "install.cmd",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.cjs",
  "bin": {
    "must-b": "bin/must-b.cjs"
  },
  "scripts": {
    "start": "tsx src/index.ts web",
    "start:cli": "tsx src/index.ts cli",
    "dev": "tsx watch src/index.ts web",
    "doctor": "tsx src/index.ts doctor",
    "onboard": "tsx src/index.ts onboard",
    "memory-sync": "tsx src/index.ts memory-sync",
    "build:frontend": "cd public/must-b-ui && npm install && npx vite build",
    "dev:frontend": "cd public/must-b-ui && npm install && npx vite",
    "build:prod": "node scripts/build-prod.mjs",
    "build:bin": "node scripts/build-prod.mjs --binary"
  },
  "pkg": {
    "assets": [
      "dist/public/**/*"
    ],
    "scripts": [
      "dist/index.cjs"
    ],
    "targets": [
      "node20-win-x64",
      "node20-linux-x64",
      "node20-macos-x64"
    ],
    "outputPath": "dist/bin"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "chalk": "^5.0.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vectra": "^0.12.3",
    "winston": "^3.11.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^5.11.5",
    "esbuild": "^0.24.0",
    "eslint": "^8",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
