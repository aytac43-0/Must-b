{
  "name": "must-b",
  "version": "2.0.0",
  "description": "Must-b v2.0 — Auto Step Edition",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "must-b": "./dist/index.js"
  },
  "scripts": {
    "start": "node --loader ts-node/esm src/index.ts web",
    "start:web": "node --loader ts-node/esm src/index.ts web",
    "start:cli": "node --loader ts-node/esm src/index.ts cli",
    "start:frontend": "cd public/Luma && npm start",
    "dev": "node --loader ts-node/esm --watch src/index.ts web",
    "dev:frontend": "cd public/Luma && npm run dev",
    "build:frontend": "cd public/Luma && npm run build",
    "install:frontend": "cd public/Luma && npm install"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "socket.io": "^4.8.3",
    "chalk": "^5.0.0",
    "next": "^13.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.2.4",
    "autoprefixer": "^10.4.13",
    "postcss": "^8.4.21",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
