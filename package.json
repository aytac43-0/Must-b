{
  "name": "must-b",
  "version": "2.0.0",
  "description": "Must-b v2.0 — Auto Step Edition",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "must-b": "bin/must-b.cjs"
  },
  "scripts": {
    "start": "tsx src/index.ts web",
    "start:cli": "tsx src/index.ts cli",
    "dev": "tsx watch src/index.ts web",
    "doctor": "tsx src/index.ts doctor",
    "onboard": "tsx src/index.ts onboard",
    "memory-sync": "tsx src/index.ts memory-sync",
    "build:frontend": "cd public/must-b-ui && npm install && npx vite build",
    "dev:frontend": "cd public/must-b-ui && npm install && npx vite",
    "push": "git add . && git commit -m \"Auto-update by Claude\" && git push",
    "build:prod": "node scripts/build-prod.mjs"
  },
  "dependencies": {
    "chalk": "^5.0.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "eslint": "^8",
    "playwright": "^1.49.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  }
}
